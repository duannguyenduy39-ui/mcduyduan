    <script>
        // Khởi tạo icons
        lucide.createIcons();

        // CHUYỂN TAB
        function switchTab(tabId) {
            // Cập nhật Buttons
            const buttons = document.querySelectorAll('.tab-btn');
            buttons.forEach(btn => {
                if (btn.getAttribute('data-tab') === tabId) {
                    btn.classList.add('bg-blue-600', 'text-white');
                    btn.classList.remove('text-slate-600', 'dark:text-slate-400', 'hover:bg-slate-100', 'dark:hover:bg-slate-800');
                } else {
                    btn.classList.remove('bg-blue-600', 'text-white');
                    btn.classList.add('text-slate-600', 'dark:text-slate-400', 'hover:bg-slate-100', 'dark:hover:bg-slate-800');
                }
            });

            // Cập nhật Nội dung
            const contents = document.querySelectorAll('.tab-content');
            contents.forEach(content => {
                content.classList.remove('active');
            });
            document.getElementById('tab-' + tabId).classList.add('active');
        }

        // TÙY CHỈNH (CUSTOMIZER)
        function toggleCustomizer() {
            const panel = document.getElementById('customizer-panel');
            if (panel.style.right === '0px') {
                panel.style.right = '-300px';
            } else {
                panel.style.right = '0px';
            }
        }

        function changeThemeColor(color) {
            // Thay đổi màu text, bg, border chủ đạo
            const themeTexts = document.querySelectorAll('.theme-text');
            const themeBgs = document.querySelectorAll('.bg-blue-600');
            const toggleBg = document.getElementById('dark-mode-toggle');
            
            document.documentElement.style.setProperty('--theme-primary', color);
            
            themeBgs.forEach(el => el.style.backgroundColor = color);
            document.getElementById('display-role').style.color = color;
            document.getElementById('display-name').style.color = color;
            if(document.body.classList.contains('dark-mode')) {
                toggleBg.style.backgroundColor = color;
            }
        }

        function toggleDarkMode() {
            const body = document.getElementById('main-body');
            const toggle = document.getElementById('dark-mode-toggle');
            body.classList.toggle('dark-mode');
            
            if (body.classList.contains('dark-mode')) {
                body.classList.replace('bg-slate-50', 'bg-slate-950');
                body.classList.replace('text-slate-900', 'text-slate-100');
            } else {
                body.classList.replace('bg-slate-950', 'bg-slate-50');
                body.classList.replace('text-slate-100', 'text-slate-900');
            }
        }

        function updateContent(elementId, value) {
            document.getElementById(elementId).innerText = value;
        }

        // Đóng panel nếu click ra ngoài
        document.addEventListener('mousedown', (e) => {
            const panel = document.getElementById('customizer-panel');
            const settingsBtn = document.querySelector('[onclick="toggleCustomizer()"]');
            if (!panel.contains(e.target) && !settingsBtn.contains(e.target) && panel.style.right === '0px') {
                toggleCustomizer();
            }
        });
    </script>
</body>
</html>
